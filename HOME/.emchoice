#  .emchoice
#
#echo ".emchoice ***"

export EMACS24=/Users/Akira/Applications/24.5/Emacs.app/Contents/MacOS/Emacs
export EMACS25=/Users/Akira/Applications/25.3/Emacs.app/Contents/MacOS/Emacs
export EMACS26=/Users/Akira/Applications/26.3/Emacs.app/Contents/MacOS/Emacs
export EMACS27=/Users/Akira/Applications/27.2/Emacs.app/Contents/MacOS/Emacs
export EMACS28=/Users/Akira/Applications/28.2/Emacs.app/Contents/MacOS/Emacs
export EMACS29=/Users/Akira/Applications/29.4/Emacs.app/Contents/MacOS/Emacs
export EMACS30=/Applications/Emacs.app/Contents/MacOS/Emacs
#export EMACS=$EMACS30

[ $EMACS ] && alias emacs=$EMACS
alias emacs24=$EMACS24
alias emacs25=$EMACS25
alias emacs26=$EMACS26
alias emacs27=$EMACS27
alias emacs28=$EMACS28
alias emacs29=$EMACS29
alias emacs30=$EMACS30
##alias emacs=emacs28

alias em='emacs -nw'
alias em24='emacs24 -nw'
alias em25='emacs25 -nw'
alias em26='emacs26 -nw'
alias em27='emacs27 -nw'
alias em28='emacs28 -nw'
alias em29='emacs29 -nw'
alias em30='emacs30 -nw'

alias emax='emacs &!'     #!disown zsh

alias emx='TERM=xterm emacs -nw'
alias emt='TERM=vt100 VT100=yes emacs -nw'
alias emv='TERM_PROGRAM=vscode emacs -nw'
alias empu='PUTTY=yes emacs -nw'
alias emd='emacs -nw --debug-init'

alias emah='HOME=$PWD emacs'
 
alias emal='emacs -q -l .emacs.d/init.el'

